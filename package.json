{
  "name": "watchline",
  "version": "0.2.0",
  "description": "Tiny serverless uptime and page-change monitor for Cloudflare Workers.",
  "type": "module",
  "license": "MIT",
  "author": "The Vibe Company",
  "homepage": "https://github.com/The-Vibe-Company/watchline#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Vibe-Company/watchline.git"
  },
  "bugs": {
    "url": "https://github.com/The-Vibe-Company/watchline/issues"
  },
  "keywords": [
    "uptime",
    "monitoring",
    "change-detection",
    "cloudflare-workers",
    "serverless",
    "watcher"
  ],
  "bin": {
    "watchline": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/worker.ts --format esm --dts --splitting false --clean --out-dir dist",
    "check": "npm run typecheck && npm test",
    "ci": "npm run check && npm run build && npm run package:verify && npm run pack:dry-run",
    "deploy": "npm run build && wrangler deploy",
    "dev": "npm run build && wrangler dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "changeset": "changeset",
    "package:verify": "node -e \"const fs = require('fs'); const missing = ['dist/index.js', 'dist/index.d.ts', 'dist/cli.js', 'dist/worker.js', 'dist/worker.d.ts'].filter((file) => !fs.existsSync(file)); if (missing.length) { console.error('Missing package output: ' + missing.join(', ')); process.exit(1); }\"",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run package:verify",
    "release:dry-run": "npm run ci && changeset status --verbose",
    "release": "changeset publish",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@cloudflare/workers-types": "^4.20260524.0",
    "@types/node": "^22.15.29",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3",
    "wrangler": "^4.18.0"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
